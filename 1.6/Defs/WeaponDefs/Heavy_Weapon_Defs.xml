    <!-- Minigun (Fallout 3/ FNV) -->

    <ThingDef ParentName="FCP_Simple_Gun_Base">
        <defName>FCP_Gun_Minigun</defName>
        <label>Minigun</label>
        <description>The Minigun is a multi-barrel, rotary machine gun capable of firing 5mm rounds at an extremely high rate. Its devastating firepower makes it a favorite for heavy support roles, but its weight and bulk limit mobility.</description>
        <smeltable>false</smeltable>
        <graphicData>
            <texPath>Weapons/Heavy_Weapons/FCP_Minigun</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <soundInteract>Interact_Rifle</soundInteract>        <thingSetMakerTags>
            <li>RewardStandardQualitySuper</li>
        </thingSetMakerTags>
        <statBases>
            <MarketValue>850</MarketValue>
            <Mass>12.0</Mass>
            <AccuracyTouch>0.50</AccuracyTouch>
            <AccuracyShort>0.45</AccuracyShort>
            <AccuracyMedium>0.30</AccuracyMedium>
            <AccuracyLong>0.10</AccuracyLong>
            <RangedWeapon_Cooldown>3.0</RangedWeapon_Cooldown>
        </statBases>
        <weaponTags>
            <li>FCP_Minigun_FO3</li>
            <li>FCP_Power_Armor_Required</li>
        </weaponTags>        <verbs>
            <li>
                <verbClass>Verb_Shoot</verbClass>
                <hasStandardCommand>true</hasStandardCommand>
                <defaultProjectile>FCP_Bullet_5mm</defaultProjectile>
                <warmupTime>2.5</warmupTime>
                <range>28</range>
                <burstShotCount>25</burstShotCount>
                <ticksBetweenBurstShots>3</ticksBetweenBurstShots>
                <soundCast>FCP_Sound_Shot_Minigun</soundCast>
                <soundCastTail>GunTail_Heavy</soundCastTail>
                <muzzleFlashScale>16</muzzleFlashScale>
            </li>
        </verbs>
        <tools>
            <li>
                <label>barrel</label>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>12</power>
                <cooldownTime>2</cooldownTime>
            </li>
        </tools>
        <comps>
            <li Class="FCP.Core.CompProperties_LabelColored">
                <rarity>Rare</rarity>
            </li>
            <li Class="FCP.Core.Backpacks.CompProperties_WeaponBackpack">
                <backpackTexPath>Things/Pawn/Backpacks/Ammo_Backpack/FCP_Ammo_Backpack</backpackTexPath>
                <backpackScale>1.0</backpackScale>
                <drawBackOnlyWhenDrafted>false</drawBackOnlyWhenDrafted>
                <northOffset>(0, 0.04, -0.10)</northOffset>
                <southOffset>(0, -0.04, -0.10)</southOffset>
                <eastOffset>(-0.3, 0.04, -0.10)</eastOffset>
            </li>
        </comps>
        <modExtensions>
            <li Class="FCP.Core.WeaponRequirementExtension">
                <requirements>
                    <li Class="FCP.Core.WeaponRequirement_AnyInner">
                        <requirements>
                            <li Class="FCP.Core.WeaponRequirement_AnyApparel">
                                <requiredApparel>
                                    <li MayRequire="Rick.FCP.PowerArmor">FCP_Apparel_Power_Armor_Frame</li>
                                </requiredApparel>
                            </li>
                        </requirements>
                    </li>
                </requirements>
            </li>
        </modExtensions>
    </ThingDef>

