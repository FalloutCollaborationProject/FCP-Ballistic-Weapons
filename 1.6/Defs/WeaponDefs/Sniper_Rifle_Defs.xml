<Defs>

    <!--__________ Ballistic Weapons __________-->

    <!--_____ Sniper Rifles _____-->

    <!-- DKS-501 Sniper Rifle -->

    <ThingDef ParentName="FCP_Complex_Gun_Base">
        <defName>FCP_Gun_DKS_501_Sniper_Rifle</defName>
        <label>DKS-501 Sniper Rifle</label>
        <description>The DKS-501 is a pre-war bolt-action sniper rifle chambered for .308 rounds. Known for its exceptional accuracy and stopping power, it is a favorite among marksmen for long-range engagements.</description>
        <smeltable>false</smeltable>
        <graphicData>
            <texPath>Weapons/Sniper_Rifles/FCP_DKS_501_Sniper_Rifle</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <soundInteract>Interact_Rifle</soundInteract>        <thingSetMakerTags>
            <li>RewardStandardQualitySuper</li>
        </thingSetMakerTags>
        <statBases>            <Mass>5.5</Mass>
            <AccuracyTouch>0.50</AccuracyTouch>
            <AccuracyShort>0.70</AccuracyShort>
            <AccuracyMedium>0.85</AccuracyMedium>
            <AccuracyLong>0.95</AccuracyLong>
            <RangedWeapon_Cooldown>2.5</RangedWeapon_Cooldown>
        </statBases>
        <weaponTags>
            <li>FCP_DKS_501_Sniper_Rifle</li>
            <li>FCP_Sniper_Rifle</li>
        </weaponTags>        <verbs>
            <li>
                <verbClass>Verb_Shoot</verbClass>
                <hasStandardCommand>true</hasStandardCommand>
                <defaultProjectile>FCP_Bullet_308mm</defaultProjectile>
                <warmupTime>2.0</warmupTime>
                <range>45</range>
                <burstShotCount>1</burstShotCount>
                <ticksBetweenBurstShots>0</ticksBetweenBurstShots>
                <soundCast>FCP_Sound_Shot_DKS_501_Sniper_Rifle</soundCast>
                <soundCastTail>GunTail_Heavy</soundCastTail>
                <muzzleFlashScale>12</muzzleFlashScale>
            </li>
        </verbs>
        <tools>
            <li>
                <label>stock</label>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>10</power>
                <cooldownTime>2</cooldownTime>
            </li>
            <li>
                <label>barrel</label>
                <capacities>
                    <li>Blunt</li>
                    <li>Poke</li>
                </capacities>
                <power>10</power>
                <cooldownTime>2</cooldownTime>
            </li>
        </tools>
        <comps>
            <li Class="FCP.Core.CompProperties_LabelColored">
                <rarity>Rare</rarity>
            </li>
        </comps>
    </ThingDef>

