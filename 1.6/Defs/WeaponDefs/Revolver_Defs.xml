    <!-- .357 Revolver -->

    <ThingDef ParentName="FCP_Simple_Gun_Base">
        <defName>FCP_Gun_357_Revolver</defName>
        <label>.357 Revolver</label>
        <description>The .357 Revolver is a classic, six-shot sidearm chambered for .357 Magnum rounds. Renowned for its reliability and stopping power, it is a favored weapon among lawmen and gunslingers in the wasteland.</description>
        <smeltable>false</smeltable>
        <graphicData>
            <texPath>Weapons/Revolvers/FCP_357_Revolver</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <soundInteract>Interact_Revolver</soundInteract>        <thingSetMakerTags>
            <li>RewardStandardQualitySuper</li>
        </thingSetMakerTags>
        <statBases>
            <MarketValue>380</MarketValue>
            <Mass>1.4</Mass>
            <AccuracyTouch>0.87</AccuracyTouch>
            <AccuracyShort>0.73</AccuracyShort>
            <AccuracyMedium>0.42</AccuracyMedium>
            <AccuracyLong>0.13</AccuracyLong>
            <RangedWeapon_Cooldown>1.0</RangedWeapon_Cooldown>
        </statBases>
        <weaponTags>
            <li>FCP_357_Revolver</li>
            <li>FCP_Revolver</li>
        </weaponTags>        <verbs>
            <li>
                <verbClass>Verb_Shoot</verbClass>
                <hasStandardCommand>true</hasStandardCommand>
                <defaultProjectile>FCP_Bullet_357mm</defaultProjectile>
                <warmupTime>0.45</warmupTime>
                <range>21</range>
                <burstShotCount>1</burstShotCount>
                <ticksBetweenBurstShots>0</ticksBetweenBurstShots>
                <soundCast>FCP_Sound_Shot_357_Revolver</soundCast>
                <soundCastTail>GunTail_Light</soundCastTail>
                <muzzleFlashScale>2.7</muzzleFlashScale>
            </li>
        </verbs>
        <tools>
            <li>
                <label>grip</label>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>4.5</power>
                <cooldownTime>2</cooldownTime>
            </li>
            <li>
                <label>barrel</label>
                <capacities>
                    <li>Blunt</li>
                    <li>Poke</li>
                </capacities>
                <power>4.5</power>
                <cooldownTime>2</cooldownTime>
            </li>
        </tools>
    </ThingDef>

    <!-- .44 Magnum Revolver -->

    <ThingDef ParentName="FCP_Simple_Gun_Base">
        <defName>FCP_Gun_44Magnum_Revolver</defName>
        <label>.44 Magnum Revolver</label>
        <description>The .44 Magnum Revolver is a powerful, six-shot sidearm chambered for .44 Magnum rounds. Renowned for its high stopping power and intimidating presence, it is a prized weapon among wasteland hunters and enforcers.</description>
        <smeltable>false</smeltable>
        <graphicData>
            <texPath>Weapons/Revolvers/FCP_44Magnum_Revolver</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <soundInteract>Interact_Revolver</soundInteract>        <thingSetMakerTags>
            <li>RewardStandardQualitySuper</li>
        </thingSetMakerTags>
        <statBases>
            <MarketValue>520</MarketValue>
            <Mass>1.7</Mass>
            <AccuracyTouch>0.85</AccuracyTouch>
            <AccuracyShort>0.70</AccuracyShort>
            <AccuracyMedium>0.40</AccuracyMedium>
            <AccuracyLong>0.12</AccuracyLong>
            <RangedWeapon_Cooldown>1.2</RangedWeapon_Cooldown>
        </statBases>
        <weaponTags>
            <li>FCP_44Magnum_Revolver</li>
            <li>FCP_Revolver</li>
        </weaponTags>        <verbs>
            <li>
                <verbClass>Verb_Shoot</verbClass>
                <hasStandardCommand>true</hasStandardCommand>
                <defaultProjectile>FCP_Bullet_44Magnum</defaultProjectile>
                <warmupTime>0.55</warmupTime>
                <range>22</range>
                <burstShotCount>1</burstShotCount>
                <ticksBetweenBurstShots>0</ticksBetweenBurstShots>
                <soundCast>FCP_Sound_Shot_44Magnum_Revolver</soundCast>
                <soundCastTail>GunTail_Light</soundCastTail>
                <muzzleFlashScale>3.0</muzzleFlashScale>
            </li>
        </verbs>
        <tools>
            <li>
                <label>grip</label>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>5</power>
                <cooldownTime>2</cooldownTime>
            </li>
            <li>
                <label>barrel</label>
                <capacities>
                    <li>Blunt</li>
                    <li>Poke</li>
                </capacities>
                <power>5</power>
                <cooldownTime>2</cooldownTime>
            </li>
        </tools>
    </ThingDef>

    <!-- Hunting Revolver -->

    <ThingDef ParentName="FCP_Simple_Gun_Base">
        <defName>FCP_Gun_Hunting_Revolver</defName>
        <label>Hunting Revolver</label>
        <description>The Hunting Revolver is a large, single-action revolver chambered for .45-70 Government rounds. Designed for hunting big game, it delivers devastating power and accuracy, but its heavy frame and slow rate of fire make it unwieldy in close combat.</description>
        <smeltable>false</smeltable>
        <graphicData>
            <texPath>Weapons/Revolvers/FCP_Hunting_Revolver</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <soundInteract>Interact_Revolver</soundInteract>        <thingSetMakerTags>
            <li>RewardStandardQualitySuper</li>
        </thingSetMakerTags>
        <statBases>
            <MarketValue>650</MarketValue>
            <Mass>2.4</Mass>
            <AccuracyTouch>0.82</AccuracyTouch>
            <AccuracyShort>0.75</AccuracyShort>
            <AccuracyMedium>0.48</AccuracyMedium>
            <AccuracyLong>0.18</AccuracyLong>
            <RangedWeapon_Cooldown>1.5</RangedWeapon_Cooldown>
        </statBases>
        <weaponTags>
            <li>FCP_Hunting_Revolver</li>
            <li>FCP_Revolver</li>
        </weaponTags>        <verbs>
            <li>
                <verbClass>Verb_Shoot</verbClass>
                <hasStandardCommand>true</hasStandardCommand>
                <defaultProjectile>FCP_Bullet_4570mm</defaultProjectile>
                <warmupTime>0.7</warmupTime>
                <range>26</range>
                <burstShotCount>1</burstShotCount>
                <ticksBetweenBurstShots>0</ticksBetweenBurstShots>
                <soundCast>FCP_Sound_Shot_Hunting_Revolver</soundCast>
                <soundCastTail>GunTail_Medium</soundCastTail>
                <muzzleFlashScale>3.8</muzzleFlashScale>
            </li>
        </verbs>
        <tools>
            <li>
                <label>grip</label>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>6</power>
                <cooldownTime>2</cooldownTime>
            </li>
            <li>
                <label>barrel</label>
                <capacities>
                    <li>Blunt</li>
                    <li>Poke</li>
                </capacities>
                <power>6</power>
                <cooldownTime>2</cooldownTime>
            </li>
        </tools>
    </ThingDef>

    <!-- Police Pistol -->

    <ThingDef ParentName="FCP_Simple_Gun_Base">
        <defName>FCP_Gun_Police_Pistol</defName>
        <label>Police Pistol</label>
        <description>The Police Pistol is a pre-war double-action revolver chambered for .357 Magnum rounds. Found throughout the Sierra Madre, it was standard issue for many law enforcement agencies before the war. Reliable and well-balanced for quick draw situations.</description>
        <smeltable>false</smeltable>
        <graphicData>
            <texPath>Weapons/Revolvers/FCP_Police_Pistol</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <soundInteract>Interact_Revolver</soundInteract>        <thingSetMakerTags>
            <li>RewardStandardQualitySuper</li>
        </thingSetMakerTags>
        <statBases>
            <MarketValue>380</MarketValue>
            <Mass>1.2</Mass>
            <AccuracyTouch>0.80</AccuracyTouch>
            <AccuracyShort>0.72</AccuracyShort>
            <AccuracyMedium>0.50</AccuracyMedium>
            <AccuracyLong>0.22</AccuracyLong>
            <RangedWeapon_Cooldown>1.0</RangedWeapon_Cooldown>
        </statBases>
        <weaponTags>
            <li>FCP_Police_Pistol</li>
            <li>FCP_Revolver</li>
        </weaponTags>
        <verbs>
            <li>
                <verbClass>Verb_Shoot</verbClass>
                <hasStandardCommand>true</hasStandardCommand>
                <defaultProjectile>FCP_Bullet_357mm</defaultProjectile>
                <warmupTime>0.45</warmupTime>
                <range>20</range>
                <burstShotCount>1</burstShotCount>
                <ticksBetweenBurstShots>0</ticksBetweenBurstShots>
                <soundCast>FCP_Sound_Shot_357_Revolver</soundCast>
                <soundCastTail>GunTail_Medium</soundCastTail>
                <muzzleFlashScale>3</muzzleFlashScale>
            </li>
        </verbs>
        <tools>
            <li>
                <label>grip</label>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>5</power>
                <cooldownTime>2</cooldownTime>
            </li>
            <li>
                <label>barrel</label>
                <capacities>
                    <li>Blunt</li>
                    <li>Poke</li>
                </capacities>
                <power>5</power>
                <cooldownTime>2</cooldownTime>
            </li>
        </tools>
        <comps>
            <li Class="FCP.Core.CompProperties_LabelColored">
                <rarity>Rare</rarity>
            </li>
        </comps>
    </ThingDef>

</Defs>
